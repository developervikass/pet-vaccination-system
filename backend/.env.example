# Database selection:
# DB_ENGINE=sqlite  -> uses SQLite file backend/db.sqlite3
# DB_ENGINE=mysql   -> uses MySQL with values below
DB_ENGINE=sqlite

# MySQL settings (used only when DB_ENGINE=mysql)
DB_NAME=pet_vaccination_db
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_HOST=127.0.0.1
DB_PORT=3306

# Email settings (optional override)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=you@example.com
# EMAIL_HOST_PASSWORD=app_password
